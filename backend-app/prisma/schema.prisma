generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  profileImage String?
  password     String
  role         Role    @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  age    Int?
  height Float?
  weight Float?
  gender String?

  isVerified Boolean @default(false)

  scans        NutritionScan[]
  subscription Subscription?
}

model OTPVerification {
  id        String   @id @default(cuid())

  email     String
  otp       String

  expiresAt DateTime

  verified  Boolean @default(false)

  createdAt DateTime @default(now())
}

model NutritionScan {
  id String @id @default(cuid())

  userId String

  imageUrl    String?
  productName String?

  sugar       Float?
  sugarStatus String?
  aiSummary   String?
  sugarGrade  String?

  consumedAt DateTime @default(now())

  consumptionPeriod String?

  dayKey   String?
  weekKey  String?
  monthKey String?
  yearKey  String?

  createdAt DateTime @default(now())
  scannedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Subscription {
  id String @id @default(cuid())

  userId String @unique

  status    String
  expiresAt DateTime

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  PREMIUM
}

enum NutritionLevel {
  LOW
  MEDIUM
  HIGH
}

enum ScheduleType {
  DAILY
  WEEKLY
  MONTHLY
}
